FROM nginx:alpine

# Copy static assets
COPY webapp/static /usr/share/nginx/html

# Copy Nginx configuration template for runtime environment variable substitution
# The official Nginx image will use envsubst to process this into /etc/nginx/conf.d/default.conf
COPY default.conf.template /etc/nginx/templates/default.conf.template

# Default environment variable for the proxy destination
ENV API_HOST=http://localhost:5000

EXPOSE 80
